              "path": ["api", "blogs", "1"]
            }
          }
        },
        {
          "name": "Create Blog",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "blog[title_en]", "value": "My Tech Blog", "type": "text" },
                { "key": "blog[title_ar]", "value": "بلج التقنية", "type": "text" },
                { "key": "blog[slug]", "value": "my-tech-blog", "type": "text" },
                { "key": "blog[category]", "value": "digital_marketing", "type": "text" },
                { "key": "blog[is_published]", "value": "false", "type": "text" },
                { "key": "blog[image]", "value": "", "type": "file" }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/blogs",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs"]
            }
          }
        },
        {
          "name": "Update Blog",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "blog[title_en]", "value": "Updated Blog Title", "type": "text" },
                { "key": "blog[is_published]", "value": "true", "type": "text" }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/blogs/1",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs", "1"]
            }
          }
        },
        {
          "name": "Delete Blog",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/api/blogs/1",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs", "1"]
            }
