                { "key": "blog[contents_attributes][0][key]", "value": "intro", "type": "text" },
                { "key": "blog[contents_attributes][0][value]", "value": "Welcome to the blog!", "type": "text" },
                { "key": "blog[contents_attributes][0][content_photos_attributes][0][photo]", "type": "file", "src": "" }
              ]
            },
            "url": "http://localhost:3000/api/blogs"
          }
        },
        {
          "name": "Update Blog",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "blog[title_en]", "value": "Updated Blog Title", "type": "text" },
                { "key": "blog[contents_attributes][0][id]", "value": "1", "type": "text" },
                { "key": "blog[contents_attributes][0][value]", "value": "Updated content string!", "type": "text" }
              ]
            },
            "url": "http://localhost:3000/api/blogs/1"
