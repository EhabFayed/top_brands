  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Signup - Create Editor (Manager token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "user[name]", "value": "New Editor", "type": "text" },
                { "key": "user[email]", "value": "editor@topbrand.com", "type": "text" },
                { "key": "user[password]", "value": "password123", "type": "text" },
                { "key": "user[password_confirmation]", "value": "password123", "type": "text" },
                { "key": "user[role]", "value": "editor", "type": "text", "description": "Manager can set: editor or manager. Admin can set: editor, manager, admin" },
                { "key": "user[image]", "value": "", "type": "file" }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/signup",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "signup"]
            }
          }
        },
        {
          "name": "Signup - Create Manager (Admin token only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "user[name]", "value": "New Manager", "type": "text" },
                { "key": "user[email]", "value": "manager@topbrand.com", "type": "text" },
                { "key": "user[password]", "value": "password123", "type": "text" },
                { "key": "user[password_confirmation]", "value": "password123", "type": "text" },
                { "key": "user[role]", "value": "manager", "type": "text", "description": "Only admin can create manager or admin users" },
                { "key": "user[image]", "value": "", "type": "file" }
              ]
            },
            "url": {
              "raw": "http://localhost:3000/api/signup",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@topbrand.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/login",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Blogs (Admin & Manager only)",
      "item": [
        {
          "name": "List Blogs — Page 1 (default)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/api/blogs?page=1&items=20",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs"],
              "query": [
                { "key": "page",  "value": "1",  "description": "Page number (default: 1)" },
                { "key": "items", "value": "20", "description": "Items per page (default: 20)" }
              ]
            },
            "description": "Returns a paginated list of blogs.\n\n**Response shape:**\n```json\n{\n  \"pagination\": {\n    \"current_page\": 1,\n    \"total_pages\": 5,\n    \"total_count\": 98,\n    \"items_per_page\": 20,\n    \"next_page\": 2,\n    \"prev_page\": null\n  },\n  \"data\": [ { \"id\": 1, \"title_en\": \"...\", \"...\" } ]\n}\n```\n\n**Pagination params:**\n- `page` — page number to fetch (integer, default `1`)\n- `items` — number of records per page (integer, default `20`)\n\nUse `pagination.next_page` / `pagination.prev_page` to navigate (null means no more pages)."
          }
        },
        {
          "name": "List Blogs — Page 2",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/api/blogs?page=2&items=20",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs"],
              "query": [
                { "key": "page",  "value": "2" },
                { "key": "items", "value": "20" }
              ]
            },
            "description": "Example of fetching the second page."
          }
        },
        {
          "name": "List Blogs — Custom page size (10 per page)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:3000/api/blogs?page=1&items=10",
              "protocol": "http", "host": ["localhost"], "port": "3000",
              "path": ["api", "blogs"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "items", "value": "10", "description": "Override default page size" }
              ]
            },
            "description": "Example of fetching only 10 blogs per page."
          }
        },
        {
          "name": "Show Blog",
