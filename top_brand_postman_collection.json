    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "user[name]", "value": "Admin", "type": "text" },
                { "key": "user[email]", "value": "admin@topbrand.com", "type": "text" },
                { "key": "user[password]", "value": "password123", "type": "text" },
                { "key": "user[password_confirmation]", "value": "password123", "type": "text" },
                { "key": "user[image]", "type": "file", "src": "" }
              ]
            },
            "url": "http://localhost:3000/api/signup"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@topbrand.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "http://localhost:3000/api/login"
          }
        }
      ]
    },
